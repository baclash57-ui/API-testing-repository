      "name": "Create a board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "// Save the board ID for later use\r",
              "pm.environment.set(\"BoardID\", jsonData.id);\r",
              "\r",
              "// Basic response checks\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Response is valid JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "// Field existence and type checks\r",
              "pm.test(\"Board 'name' field exists and is a string\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"name\");\r",
              "    pm.expect(jsonData.name).to.be.a(\"string\").and.not.empty;\r",
              "});\r",
              "pm.test(\"Board 'id' field exists and is a string\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"id\");\r",
              "    pm.expect(jsonData.id).to.be.a(\"string\").and.not.empty;\r",
              "});\r",
              "pm.test(\"Board 'desc' field exists and is a string\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"desc\");\r",
              "    pm.expect(jsonData.desc).to.be.a(\"string\");\r",
              "});\r",
              "pm.test(\"Board 'descData' field exists\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"descData\");\r",
              "});\r",
              "pm.test(\"Board 'url' field exists and is a valid URL\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"url\");\r",
              "    pm.expect(jsonData.url).to.be.a(\"string\").and.include(\"trello.com\");\r",
              "});\r",
              "pm.test(\"Board 'shortUrl' field exists and is a valid URL\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"shortUrl\");\r",
              "    pm.expect(jsonData.shortUrl).to.be.a(\"string\").and.include(\"trello.com\");\r",
              "});\r",
              "pm.test(\"Board 'prefs' field exists and is an object\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"prefs\");\r",
              "    pm.expect(jsonData.prefs).to.be.an(\"object\").and.not.empty;\r",
              "});\r",
              "pm.test(\"Board 'labelNames' field exists and is an object\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"labelNames\");\r",
              "    pm.expect(jsonData.labelNames).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "const createdBoardName = pm.variables.get(\"boardName\");\r",
              "\r",
              "pm.test(\"Board name is correct\", function () {\r",
              "    pm.expect(jsonData.name).to.equal(createdBoardName);\r",
              "});\r",
              "\r",
              "//board created contains the following fields\r",
              "pm.test(\"Body matches string\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"id\");\r",
              "    pm.expect(pm.response.text()).to.include(\"name\");\r",
              "    pm.expect(pm.response.text()).to.include(\"desc\");\r",
              "    pm.expect(pm.response.text()).to.include(\"descData\");\r",
              "    pm.expect(pm.response.text()).to.include(\"closed\");\r",
              "    pm.expect(pm.response.text()).to.include(\"idOrganization\");\r",
              "    pm.expect(pm.response.text()).to.include(\"idEnterprise\");\r",
              "    pm.expect(pm.response.text()).to.include(\"pinned\");\r",
              "    pm.expect(pm.response.text()).to.include(\"pinned\");\r",
              "\r",
              "});\r",
              "\r",
              ""
            ],
