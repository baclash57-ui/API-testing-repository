                  "    pm.expect(jsonData.data).to.be.an(\"object\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User data has required fields\", function () {\r",
                  "    var user = pm.response.json().data;\r",
                  "    pm.expect(user).to.have.property(\"id\");\r",
                  "    pm.expect(user).to.have.property(\"email\");\r",
                  "    pm.expect(user).to.have.property(\"first_name\");\r",
                  "    pm.expect(user).to.have.property(\"last_name\");\r",
                  "    pm.expect(user).to.have.property(\"avatar\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User ID is a number\", function () {\r",
                  "    var user = pm.response.json().data;\r",
                  "    pm.expect(user.id).to.be.a(\"number\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User email is a valid format\", function () {\r",
                  "    var user = pm.response.json().data;\r",
                  "    pm.expect(user.email).to.be.a(\"string\");\r",
                  "    pm.expect(user.email).to.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User avatar is a valid URL\", function () {\r",
                  "    var user = pm.response.json().data;\r",
                  "    pm.expect(user.avatar).to.be.a(\"string\");\r",
                  "    pm.expect(user.avatar).to.match(/^https?:\\/\\/.+/);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has support object\", function () {\r",
